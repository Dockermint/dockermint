# ============================================================================
# Dockermint Secrets
# ============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================================

# GitHub API authentication (for private repos and higher rate limits)
# GH_USER=
# GH_PAT=

# Telegram notifications (bot token from @BotFather)
# TELEGRAM_TOKEN=
# TELEGRAM_CHAT_ID=

# Container registry credentials
# REGISTRY_USER=
# REGISTRY_PASSWORD=
